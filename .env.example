OPENAI_API_KEY=your-api-key

# Optional. Send traces, logs, and metrics to a hosted Mastra Platform project.
# Create a token with: mastra auth tokens create exporter-token
# Find your project ID with: mastra studio deploy list
# MASTRA_PLATFORM_ACCESS_TOKEN=your-platform-access-token
# MASTRA_PROJECT_ID=your-project-id

# Required to actually schedule posts via the social-media-workflow's Buffer integration.
# Generate a personal access token at https://publish.buffer.com/settings/api
BUFFER_API_KEY=your-buffer-api-key

# Base URL the social-media-workflow uses to build links to AI-generated images. Buffer
# fetches these URLs server-side, so for real publishing this must be a publicly
# reachable URL (e.g. a tunnel or deployment), not localhost. Defaults to
# http://localhost:4111, which is fine for previewing drafts without publishing images.
# PUBLIC_BASE_URL=https://your-public-url

# Optional. Lets the Content Creator shorten article URLs via Dub's MCP server before
# inserting them into posts. Generate an API key at https://app.dub.co/settings/tokens.
# Without it, posts link directly to the full article URL.
# DUB_API_KEY=your-dub-api-key
