OPENAI_API_KEY=your-api-key
DEEPSEEK_API_KEY=your-api-key

# Optional. Override default models for A/B testing (see docs/agents.md#ab-testing-model-overrides).
# RESEARCHER_MODEL=deepseek/deepseek-v4-flash
# WRITER_MODEL=openai/gpt-5
# EDITOR_MODEL=openai/gpt-5-mini
# STRATEGIST_MODEL=openai/gpt-5-nano
# CONTENT_CREATOR_MODEL=openai/gpt-5-mini
# GRAPHIC_DESIGNER_MODEL=openai/gpt-4.1-nano
# OBSERVATIONAL_MEMORY_MODEL=openai/gpt-4.1-nano
# IMAGE_GENERATION_MODEL=gpt-image-1-mini

# Optional. Send traces, logs, and metrics to a hosted Mastra Platform project.
# Create a token with: mastra auth tokens create exporter-token
# Find your project ID with: mastra studio deploy list
# MASTRA_PLATFORM_ACCESS_TOKEN=your-platform-access-token
# MASTRA_PROJECT_ID=your-project-id

# Base URL the social-media-workflow uses to build links to AI-generated images.
# Defaults to http://localhost:4111, which is fine for local Studio preview.
# For sharing image URLs outside this machine, set a publicly reachable URL
# (e.g. a tunnel or deployment).
# PUBLIC_BASE_URL=https://your-public-url

# Optional. When set together with articleUrl on social-media-workflow, the workflow shortens
# that URL once via Dub's link API (idempotent upsert) before any agent sees it.
# DUB_API_KEY=your-dub-api-key
